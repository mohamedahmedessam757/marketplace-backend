generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
  SUPPORT

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED

  @@map("user_status")
}

enum StoreStatus {
  PENDING_DOCUMENTS
  PENDING_REVIEW
  ACTIVE
  REJECTED
  SUSPENDED
  BLOCKED
  LICENSE_EXPIRED

  @@map("store_status")
}

enum OrderStatus {
  AWAITING_OFFERS
  AWAITING_PAYMENT
  PREPARATION
  PREPARED
  VERIFICATION
  VERIFICATION_SUCCESS
  READY_FOR_SHIPPING
  NON_MATCHING
  CORRECTION_PERIOD
  CORRECTION_SUBMITTED
  DELAYED_PREPARATION
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
  DISPUTED
  RETURN_REQUESTED
  RETURN_APPROVED
  REFUNDED
  RESOLVED
  CLOSED

  @@map("order_status")
}

enum ActorType {
  SYSTEM
  ADMIN
  CUSTOMER
  VENDOR

  @@map("actor_type")
}

enum LoyaltyTier {
  BASIC
  SILVER
  GOLD
  VIP
  PARTNER

  @@map("loyalty_tier")
}

enum DocType {
  CR
  LICENSE
  ID
  IBAN
  AUTH_LETTER

  @@map("doc_type")
}

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String     @unique
  phone           String?    @unique
  passwordHash    String     @map("password_hash")
  countryCode     String?    @map("country_code")
  country         String?    @map("country")
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  name            String?
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz
  otpCode         String?    @map("otp_code")
  otpExpiresAt    DateTime?  @map("otp_expires_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  // Relations
  store         Store?
  orders        Order[]
  notifications Notification[]
  returns       ReturnRequest[]
  disputes      Dispute[]
  orderChats    OrderChat[]
  settings      UserSettings?
  avatar        String?         @map("avatar")

  // Security & Recovery
  recoveryStatus         String?   @map("recovery_status") // e.g., 'PENDING_REVIEW'
  withdrawalsFrozenUntil DateTime? @map("withdrawals_frozen_until") @db.Timestamptz
  lastLoginIp            String?   @map("last_login_ip")
  lastLoginDevice        String?   @map("last_login_device")

  accountRecoveryRequests AccountRecoveryRequest[]
  securityLogs            SecurityLog[]
  payments                PaymentTransaction[]
  cards                   UserCard[]
  Session                 Session[]
  createdContracts        PlatformContract[]
  verificationReviews     VerificationDocument[]

  adminNotes       String?           @map("admin_notes") @db.Text
  shippingWaybills ShippingWaybill[]

  // Payout & Stripe Details
  bankName            String? @map("bank_name")
  bankAccountHolder   String? @map("bank_account_holder")
  bankIban            String? @map("bank_iban")
  bankSwift           String? @map("bank_swift")
  bankDetailsVerified Boolean @default(false) @map("bank_details_verified")
  stripeAccountId     String? @map("stripe_account_id")
  stripeOnboarded     Boolean @default(false) @map("stripe_onboarded")

  // Loyalty & Referral System
  customerBalance Decimal     @default(0) @map("customer_balance") @db.Decimal(14, 2)
  loyaltyTier     LoyaltyTier @default(BASIC) @map("loyalty_tier")
  totalSpent      Decimal     @default(0) @map("total_spent") @db.Decimal(14, 2)
  loyaltyPoints   Int         @default(0) @map("loyalty_points")
  referralCount   Int         @default(0) @map("referral_count")
  referralCode    String?     @unique @map("referral_code")
  referredById    String?     @map("referred_by_id") @db.Uuid
  referredBy      User?       @relation("ReferralHistory", fields: [referredById], references: [id])
  referredUsers   User[]      @relation("ReferralHistory")

  withdrawalRequests WithdrawalRequest[]

  // Reviews
  submittedReviews Review[]

  // Shipping Management
  updatedShipments        Shipment[]
  changedShipmentStatuses ShipmentStatusLog[]

  // Phase 4: Case Messaging
  caseMessages CaseMessage[]

  @@map("users")
}

enum StoreLoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM

  @@map("store_loyalty_tier")
}

model UserSettings {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @unique @map("user_id") @db.Uuid
  autoTranslateChat Boolean @default(false) @map("auto_translate_chat")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Store {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String      @unique @map("owner_id") @db.Uuid
  name            String
  storeCode       String      @unique @map("store_code")
  slug            String?     @unique
  description     String?
  category        String?
  logo            String?     @map("logo")
  status          StoreStatus @default(PENDING_DOCUMENTS)
  licenseExpiry   DateTime?   @map("license_expiry") @db.Date
  balance         Decimal     @default(0) @db.Decimal(14, 2)
  pendingBalance  Decimal     @default(0) @map("pending_balance") @db.Decimal(14, 2)
  frozenBalance   Decimal     @default(0) @map("frozen_balance") @db.Decimal(14, 2)
  stripeAccountId String?     @map("stripe_account_id")
  stripeOnboarded Boolean     @default(false) @map("stripe_onboarded")
  payoutSchedule  String      @default("MANUAL") @map("payout_schedule")

  // Bank Transfer Details
  bankName              String?  @map("bank_name")
  bankAccountHolder     String?  @map("bank_account_holder")
  bankIban              String?  @map("bank_iban")
  bankSwift             String?  @map("bank_swift")
  bankDetailsVerified   Boolean  @default(false) @map("bank_details_verified")
  rating          Decimal     @default(0) @db.Decimal(3, 2)
  rejectionReason String?     @map("rejection_reason")

  // Loyalty & Reputation System
  loyaltyTier      StoreLoyaltyTier @default(BRONZE) @map("loyalty_tier")
  performanceScore Decimal          @default(0) @map("performance_score") @db.Decimal(10, 2)
  lifetimeEarnings Decimal          @default(0) @map("lifetime_earnings") @db.Decimal(14, 2)

  // Car Specializations
  selectedMakes  String[] @default([]) @map("selected_makes")
  selectedModels String[] @default([]) @map("selected_models")
  customMake     String?  @map("custom_make")
  customModel    String?  @map("custom_model")

  // Contract data
  contractId         String?           @map("contract_id") @db.Uuid
  contract           PlatformContract? @relation(fields: [contractId], references: [id])
  contractAcceptedAt DateTime?         @map("contract_accepted_at") @db.Timestamptz
  contractSignature  String?           @map("contract_signature") @db.VarChar(255)

  // Location
  address String?
  lat     Decimal? @db.Decimal(10, 8)
  lng     Decimal? @db.Decimal(11, 8)

  adminNotes     String?   @map("admin_notes") @db.Text
  suspendedUntil DateTime? @map("suspended_until") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  // Relations
  owner                 User                   @relation(fields: [ownerId], references: [id])
  documents             StoreDocument[]
  contractAcceptances   ContractAcceptance[]
  orders                Order[]
  offers                Offer[]
  orderChats            OrderChat[]
  verificationDocuments VerificationDocument[]
  shippingWaybills      ShippingWaybill[]
  reviews               Review[]
  withdrawalRequests    WithdrawalRequest[]

  @@index([status])
  @@index([suspendedUntil])
  @@map("stores")
}

model StoreDocument {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  docType        DocType   @map("doc_type")
  fileUrl        String?   @map("file_url")
  status         String    @default("pending") // pending | approved | rejected
  rejectedReason String?   @map("rejected_reason")
  expiresAt      DateTime? @map("expires_at") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, docType])
  @@map("store_documents")
}

model Order {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber String      @unique @map("order_number")
  customerId  String      @map("customer_id") @db.Uuid
  storeId     String?     @map("store_id") @db.Uuid
  status      OrderStatus @default(AWAITING_OFFERS)

  // Vehicle Details
  vehicleMake  String  @map("vehicle_make")
  vehicleModel String  @map("vehicle_model")
  vehicleYear  Int     @map("vehicle_year") @db.SmallInt
  vin          String?
  vinImage     String? @map("vin_image")

  // Part Details
  partName        String  @map("part_name")
  partDescription String? @map("part_description")
  partImages      Json?   @default("[]") @map("part_images")

  // Preferences
  conditionPref     String?  @map("condition_pref")
  warrantyPreferred Boolean? @default(false) @map("warranty_preferred")
  requestType       String?  @map("request_type")
  shippingType      String?  @map("shipping_type")

  // Financials
  totalAmount Decimal? @map("total_amount") @db.Decimal(14, 2)

  // Timestamps
  offersDeadlineAt             DateTime? @map("offers_deadline_at") @db.Timestamptz
  paymentDeadlineAt            DateTime? @map("payment_deadline_at") @db.Timestamptz
  delayedPreparationDeadlineAt DateTime? @map("delayed_prep_deadline_at") @db.Timestamptz
  correctionDeadlineAt         DateTime? @map("correction_deadline_at") @db.Timestamptz
  verificationSubmittedAt      DateTime? @map("verification_submitted_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  // Admin Features
  adminNotes String? @map("admin_notes") @db.Text

  // Relations
  customer   User                 @relation(fields: [customerId], references: [id])
  store      Store?               @relation(fields: [storeId], references: [id])
  offers     Offer[]
  auditLogs  AuditLog[]
  parts      OrderPart[]
  returns    ReturnRequest[]
  disputes   Dispute[]
  orderChats OrderChat[]
  payments   PaymentTransaction[]
  invoices   Invoice[]
  review     Review?

  // Active Offer Relation
  acceptedOfferId String? @unique @map("offer_id") @db.Uuid
  acceptedOffer   Offer?  @relation("AcceptedOffer", fields: [acceptedOfferId], references: [id])

  // Shipping Addresses
  shippingAddresses OrderShippingAddress[]

  // Verification
  verificationDocuments VerificationDocument[]
  shippingWaybills      ShippingWaybill[]
  shipments             Shipment[]

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@map("orders")
}

model VerificationDocument {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId String @map("order_id") @db.Uuid
  storeId String @map("store_id") @db.Uuid

  images      Json    @default("[]")
  videoUrl    String? @map("video_url")
  description String?

  recipientName      String?   @map("recipient_name")
  recipientSignature String?   @map("recipient_signature")
  signatureType      String    @default("DRAWN") @map("signature_type") // DRAWN | TYPED
  signatureText      String?   @map("signature_text")
  handoverDate       DateTime? @map("handover_date") @db.Timestamptz
  handoverTime       String?   @map("handover_time")

  adminStatus          String    @default("PENDING") @map("admin_status")
  adminReviewedBy      String?   @map("admin_reviewed_by") @db.Uuid
  adminReviewedAt      DateTime? @map("admin_reviewed_at") @db.Timestamptz
  adminRejectionReason String?   @map("admin_rejection_reason")
  adminRejectionImages Json?     @default("[]") @map("admin_rejection_images")
  adminRejectionVideo  String?   @map("admin_rejection_video")

  isCorrection       Boolean @default(false) @map("is_correction")
  originalDocumentId String? @map("original_document_id") @db.Uuid

  correctionDeadlineAt DateTime? @map("correction_deadline_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  order            Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store            Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  adminReviewer    User?                  @relation(fields: [adminReviewedBy], references: [id])
  originalDocument VerificationDocument?  @relation("CorrectionChain", fields: [originalDocumentId], references: [id])
  corrections      VerificationDocument[] @relation("CorrectionChain")

  @@index([orderId])
  @@index([storeId])
  @@index([adminStatus])
  @@map("verification_documents")
}

model Offer {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offerNumber String  @unique @map("offer_number")
  orderId     String  @map("order_id") @db.Uuid
  orderPartId String? @map("order_part_id") @db.Uuid
  storeId     String  @map("store_id") @db.Uuid

  unitPrice        Decimal @map("unit_price") @db.Decimal(14, 2)
  weightKg         Decimal @map("weight_kg") @db.Decimal(8, 2)
  shippingCost     Decimal @default(0) @map("shipping_cost") @db.Decimal(14, 2)
  hasWarranty      Boolean @default(false) @map("has_warranty")
  warrantyDuration String? @map("warranty_duration")
  deliveryDays     String? @map("delivery_days")
  condition        String?
  partType         String? @map("part_type")
  notes            String?
  offerImage       String? @map("offer_image")
  status           String  @default("pending") // pending | accepted | rejected

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderPart OrderPart? @relation(fields: [orderPartId], references: [id])
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // Relation back to Order if accepted
  acceptedByOrder Order? @relation("AcceptedOffer")

  rejection OfferRejection?
  payments  PaymentTransaction[]

  @@index([orderId])
  @@index([orderPartId])
  @@index([storeId])
  @@map("offers")
}

model OfferRejection {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offerId      String   @unique @map("offer_id") @db.Uuid
  reason       String
  customReason String?  @map("custom_reason")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("offer_rejections")
}

model AuditLog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String?   @map("order_id") @db.Uuid
  action        String
  entity        String
  actorType     ActorType @map("actor_type")
  actorId       String?   @map("actor_id")
  actorName     String?   @map("actor_name")
  previousState String?   @map("previous_state")
  newState      String?   @map("new_state")
  reason        String?
  metadata      Json?
  timestamp     DateTime  @default(now()) @db.Timestamptz

  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([actorId])
  @@index([timestamp])
  @@map("audit_logs")
}

model StaticPage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique
  titleAr   String?  @map("title_ar")
  titleEn   String?  @map("title_en")
  contentAr String?  @map("content_ar")
  contentEn String?  @map("content_en")
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("static_pages")
}

model OrderPart {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  name        String
  description String?
  notes       String?
  images      String[] // Array of URLs
  video       String? // URL
  quantity    Int      @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  order            Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  offers           Offer[]
  shippingAddress  OrderShippingAddress?
  shippingWaybills ShippingWaybill[]

  @@map("order_parts")
}

model Notification {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientId   String @map("recipient_id") @db.Uuid
  recipientRole String @default("CUSTOMER") @map("recipient_role") // CUSTOMER, MERCHANT, ADMIN

  titleAr   String @map("title_ar")
  titleEn   String @map("title_en")
  messageAr String @map("message_ar")
  messageEn String @map("message_en")

  type     String  @default("system") // system, order, alert, promotion
  isRead   Boolean @default(false) @map("is_read")
  link     String? // Frontend route to redirect to
  metadata Json? // For related ID (e.g. { orderId: 123 })

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  recipient User @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([isRead])
  @@map("notifications")
}

// Renamed to ReturnRequest to avoid reserved keyword collision
model ReturnRequest {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  orderPartId String? @map("order_part_id") @db.Uuid
  offerId     String? @map("offer_id") @db.Uuid
  customerId  String  @map("customer_id") @db.Uuid

  reason        String
  description   String?
  status        String  @default("PENDING")
  evidenceFiles Json    @default("[]") @map("evidence_files")

  // 2026 Enhanced Fields
  usageCondition   String?   @map("usage_condition") // UNUSED | OPENED | INSTALLED
  returnType       String    @default("REFUND") @map("return_type") // REFUND | EXCHANGE
  storeId          String?   @map("store_id") @db.Uuid
  invoiceId        String?   @map("invoice_id") @db.Uuid
  shipmentId       String?   @map("shipment_id") @db.Uuid
  returnWaybillId  String?   @map("return_waybill_id") @db.Uuid
  handoverDeadline DateTime? @map("handover_deadline") @db.Timestamptz
  merchantEvidence Json      @default("[]") @map("merchant_evidence")

  // Phase 4 Governance
  verdictNotes String? @map("verdict_notes")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  customer User  @relation(fields: [customerId], references: [id])
  order    Order @relation(fields: [orderId], references: [id])

  @@map("returns")
}

model Dispute {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  orderPartId String? @map("order_part_id") @db.Uuid
  offerId     String? @map("offer_id") @db.Uuid
  customerId  String  @map("customer_id") @db.Uuid

  reason        String
  description   String?
  status        String  @default("OPEN")
  evidenceFiles Json    @default("[]") @map("evidence_files")

  // 2026 Enhanced Fields
  storeId          String? @map("store_id") @db.Uuid
  invoiceId        String? @map("invoice_id") @db.Uuid
  shipmentId       String? @map("shipment_id") @db.Uuid
  merchantEvidence Json    @default("[]") @map("merchant_evidence")

  // Phase 4 Governance
  faultParty      String?   @map("fault_party")
  refundAmount    Decimal?  @map("refund_amount") @db.Decimal(14, 2)
  shippingRefund  Decimal?  @map("shipping_refund") @db.Decimal(14, 2)
  stripeFee       Decimal?  @map("stripe_fee") @db.Decimal(14, 2)
  verdictNotes    String?   @map("verdict_notes")
  verdictIssuedAt DateTime? @map("verdict_issued_at") @db.Timestamptz
  verdictLocked   Boolean   @default(false) @map("verdict_locked")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  customer User  @relation(fields: [customerId], references: [id])
  order    Order @relation(fields: [orderId], references: [id])

  @@map("disputes")
}

model CaseMessage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId      String   @map("case_id") @db.Uuid
  caseType    String   @map("case_type") // 'return' or 'dispute'
  senderId    String   @map("sender_id") @db.Uuid
  senderRole  String   @map("sender_role") // 'CUSTOMER', 'MERCHANT', 'ADMIN'
  text        String   @db.Text
  attachments Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("case_messages")
}

model OrderChat {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String?   @map("order_id") @db.Uuid
  vendorId   String?   @map("vendor_id") @db.Uuid // Optional for support chats
  customerId String    @map("customer_id") @db.Uuid
  status     String    @default("OPEN") // OPEN, CLOSED, EXPIRED, RESOLVED (for support)
  type       String    @default("order") // order, support
  expiryAt   DateTime? @map("expiry_at") @db.Timestamptz // Optional for support

  // Role-Specific Translation Timestamps
  customerTranslationEnabledAt DateTime? @map("customer_translation_enabled_at") @db.Timestamptz
  vendorTranslationEnabledAt   DateTime? @map("vendor_translation_enabled_at") @db.Timestamptz
  adminTranslationEnabledAt    DateTime? @map("admin_translation_enabled_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  // Administrative Control (2026 Enhancement)
  isDeletedByAdmin Boolean   @default(false) @map("is_deleted_by_admin")
  adminJoinedAt    DateTime? @map("admin_joined_at") @db.Timestamptz

  messages OrderChatMessage[]

  // Relations
  order    Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor   Store? @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  customer User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Modified uniqueness constraints to allow multiple support chats per order
  @@unique([orderId, vendorId, type])
  @@index([orderId])
  @@index([vendorId])
  @@index([customerId])
  @@index([type])
  @@map("order_chats")
}

model OrderChatMessage {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId         String  @map("chat_id") @db.Uuid
  senderId       String? @map("sender_id") @db.Uuid
  text           String
  translatedText String? @map("translated_text")
  isRead         Boolean @default(false) @map("is_read")

  // Media Support Extensions
  mediaUrl  String? @map("media_url")
  mediaType String? @map("media_type") // image, video, pdf, docx
  mediaName String? @map("media_name") // To display original file name for documents

  // Administrative Moderation (2026 Enhancement)
