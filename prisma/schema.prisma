// =============================================
// PAYMENT & FINANCIAL MODELS
// =============================================

model PaymentTransaction {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionNumber String @unique @map("transaction_number")
  orderId           String @map("order_id") @db.Uuid
  offerId           String @map("offer_id") @db.Uuid
  customerId        String @map("customer_id") @db.Uuid

  // Amounts
  unitPrice    Decimal @map("unit_price") @db.Decimal(14, 2)
  shippingCost Decimal @default(0) @map("shipping_cost") @db.Decimal(14, 2)
  commission   Decimal @default(0) @db.Decimal(14, 2)
  totalAmount  Decimal @map("total_amount") @db.Decimal(14, 2)
  currency     String  @default("AED")

  // Card Info (masked)
  cardLast4  String? @map("card_last4")
  cardBrand  String? @map("card_brand")
  cardHolder String? @map("card_holder")

  // Status
  status        String  @default("PENDING") // PENDING | SUCCESS | FAILED | REFUNDED
  failureReason String? @map("failure_reason")

  // Future Stripe integration
  stripePaymentId  String?   @map("stripe_payment_id")
  stripeTransferId String?   @map("stripe_transfer_id")
  gatewayFee       Decimal   @default(0) @map("gateway_fee") @db.Decimal(14, 2)
  refundedAmount   Decimal   @default(0) @map("refunded_amount") @db.Decimal(14, 2)
  refundedAt       DateTime? @map("refunded_at") @db.Timestamptz
  refundReason     String?   @map("refund_reason")
  escrowStatus     String    @default("HELD") @map("escrow_status")

  paidAt    DateTime? @map("paid_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  order    Order @relation(fields: [orderId], references: [id])
  offer    Offer @relation(fields: [offerId], references: [id])
  customer User  @relation(fields: [customerId], references: [id])
  walletTransactions WalletTransaction[]

  @@unique([offerId]) // Prevent duplicate payments at DB level — race-condition safe
  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@map("payment_transactions")
}

model WalletTransaction {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  role      String // VENDOR | ADMIN
  paymentId String? @map("payment_id") @db.Uuid

  type            String // CREDIT | DEBIT
  transactionType String  @default("payment") @map("transaction_type") // payment | commission | refund | withdrawal | penalty
  amount          Decimal @db.Decimal(14, 2)
  currency        String  @default("AED")
  description     String?
  balanceAfter    Decimal @map("balance_after") @db.Decimal(14, 2)
  metadata        Json?   @default("{}")
  escrowId        String? @map("escrow_id") @db.Uuid

  payment PaymentTransaction? @relation(fields: [paymentId], references: [id])
  escrow  EscrowTransaction?  @relation(fields: [escrowId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([paymentId])
  @@map("wallet_transactions")
}

model EscrowTransaction {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId        String    @map("payment_id") @db.Uuid
  orderId          String    @map("order_id") @db.Uuid
  merchantAmount   Decimal   @map("merchant_amount") @db.Decimal(14, 2)
  commissionAmount Decimal   @map("commission_amount") @db.Decimal(14, 2)
  shippingAmount   Decimal   @map("shipping_amount") @db.Decimal(14, 2)
  gatewayFee       Decimal   @default(0) @map("gateway_fee") @db.Decimal(14, 2)
  status           String    @default("HELD") // HELD | RELEASED | REFUNDED | FROZEN
  releaseCondition String?   @map("release_condition") // CUSTOMER_CONFIRM | AUTO_48H | ADMIN_RELEASE
  releasedAt       DateTime? @map("released_at") @db.Timestamptz
  frozenReason     String?   @map("frozen_reason")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  walletTransactions WalletTransaction[]

  @@index([orderId])
  @@index([status])
  @@map("escrow_transactions")
}

model PlatformWallet {
