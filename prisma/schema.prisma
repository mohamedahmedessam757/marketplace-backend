// -----------------------------------------------------
// Shipping Management System
// -----------------------------------------------------

enum ShipmentStatus {
  // Step 1: Admin received shipment at hub
  RECEIVED_AT_HUB
  // Step 2: Quality check passed
  QUALITY_CHECK_PASSED
  // Step 3: Packaged and ready
  PACKAGED_FOR_SHIPPING
  // Step 4: Waiting for carrier pickup
  AWAITING_CARRIER_PICKUP
  // Step 5: Carrier picked up
  PICKED_UP_BY_CARRIER
  // Step 6: International transit
  IN_TRANSIT_TO_DESTINATION
  // Step 7: Transit hub / arrived at destination country area
  ARRIVED_AT_LOCAL_FACILITY
  // Step 8: Customs clearance (may be delayed)
  CUSTOMS_CLEARANCE
  // Step 9: At local carrier warehouse
  AT_LOCAL_WAREHOUSE
  // Step 10: Out for delivery
  OUT_FOR_DELIVERY
  // Step 11: Delivery attempted / failed attempt
  DELIVERY_ATTEMPTED
  // Step 12: Delivered to customer
  DELIVERED_TO_CUSTOMER
  // Return states
  RETURN_TO_SENDER_INITIATED
  RETURNED_TO_SENDER
  // Customs delay state
  CUSTOMS_DELAY

  @@map("shipment_status")
}

enum CarrierType {
  NO_TRACKING
  WITH_TRACKING
  API_TRACKING

  @@map("carrier_type")
}

model Shipment {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  waybillId String? @map("waybill_id") @db.Uuid

  carrierType    CarrierType @default(NO_TRACKING) @map("carrier_type")
  carrierName    String?     @map("carrier_name")
  trackingNumber String?     @map("tracking_number")
  trackingLink   String?     @map("tracking_link")
  carrierApiUrl  String?     @map("carrier_api_url")

  // Initial status when merchant requests shipping
  status           ShipmentStatus @default(RECEIVED_AT_HUB)
  statusNotes      String?        @map("status_notes")
  customsDelayNote String?        @map("customs_delay_note")

  estimatedDelivery DateTime? @map("estimated_delivery") @db.Timestamptz
  actualDelivery    DateTime? @map("actual_delivery") @db.Timestamptz
  updatedBy         String?   @map("updated_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  waybill    ShippingWaybill?    @relation(fields: [waybillId], references: [id])
  updater    User?               @relation(fields: [updatedBy], references: [id])
  statusLogs ShipmentStatusLog[]

  @@index([orderId])
  @@index([status])
  @@map("shipments")
}

model ShipmentStatusLog {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId String          @map("shipment_id") @db.Uuid
  fromStatus ShipmentStatus? @map("from_status")
  toStatus   ShipmentStatus  @map("to_status")
  changedBy  String?         @map("changed_by") @db.Uuid
  notes      String?
  source     String?         @default("MANUAL") // 'MANUAL' | 'API'

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  changer  User?    @relation(fields: [changedBy], references: [id])

  @@index([shipmentId])
  @@map("shipment_status_logs")
}

